# ================================================================
# StudioSowa — Variables d'environnement
# Copier ce fichier en .env pour le développement local
# Sur Railway : ajouter ces variables dans Settings > Variables
# ================================================================

# Clé secrète Flask (générer une clé aléatoire longue en production)
SECRET_KEY=changez-cette-cle-en-production-abc123xyz

# Mot de passe de l'interface d'administration
ADMIN_PASSWORD=sowa2024!

# ---- Base de données (Railway la remplit automatiquement) ----
# En local : laisser vide (SQLite utilisé automatiquement)
# Sur Railway : rempli automatiquement par le plugin PostgreSQL
DATABASE_URL=

# ---- Cloudinary (stockage des images) ----
# Créer un compte sur cloudinary.com (gratuit)
# Copier les valeurs depuis Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=votre-api-secret

# ---- Email Hostinger (formulaire de contact) ----
MAIL_SERVER=smtp.hostinger.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=contact@studiosowa.com
MAIL_PASSWORD=votre-mot-de-passe-email
MAIL_RECIPIENT=contact@studiosowa.com
